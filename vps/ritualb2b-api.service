[Unit]
Description=RitualB2B Agent HTTP API
After=network.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/ritualb2b
ExecStart=/root/ritualb2b/venv/bin/uvicorn vps_api:app --host 0.0.0.0 --port 8765
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
