# Telegram Bot
TELEGRAM_BOT_TOKEN=
# Твой Telegram user ID (узнать у @userinfobot — он покажет твой ID)
# Только этот ID сможет управлять ботом и слать фото.
TELEGRAM_ALLOWED_USER_ID=

# Chrome CDP
CHROME_CDP_URL=http://127.0.0.1:9333

# Пути (можно не менять, по умолчанию относительно проекта)
INPUT_DIR=input
OUTPUT_DIR=output
PROCESSED_DIR=processed
REFERENCE_DIR=reference
LOGS_DIR=logs

# Время ожидания генерации в секундах (max)
GENERATION_TIMEOUT_SEC=180

# Пауза между обработкой файлов (секунды) — чтобы не вызвать рейт-лимит
DELAY_BETWEEN_JOBS_SEC=5
