# =================================================================
# Telegram Bot
# =================================================================
TELEGRAM_BOT_TOKEN=
# Твой Telegram user ID (узнать у @userinfobot — он покажет твой ID).
# Только этот ID сможет управлять ботом и слать фото.
TELEGRAM_ALLOWED_USER_ID=

# =================================================================
# Chrome CDP — для локального агента (remote_agent.py)
# =================================================================
CHROME_CDP_URL=http://127.0.0.1:9333

# =================================================================
# ChatGPT-проекты по режимам
# =================================================================
# Каждый режим = свой проект. Эталоны в reference/<mode>/etalon_*.png,
# промпты в prompts/<mode>.txt. Если URL пустой — режим показывает
# ошибку при попытке обработки.

# 🧺 Корзинки (внутреннее имя режима — ritual, сохранено для совместимости)
RITUAL_PROJECT_URL=https://chatgpt.com/g/g-p-XXXXX-ritualb2b

# ❄️ Кондиционеры SplitHub
CONDITIONER_PROJECT_URL=

# ⚜️ Венки
WREATH_PROJECT_URL=

# Для совместимости со старыми скриптами — указывает на основной режим
CHATGPT_PROJECT_URL=

# =================================================================
# Пути (можно не менять, по умолчанию относительно проекта)
# =================================================================
INPUT_DIR=input
OUTPUT_DIR=output
PROCESSED_DIR=processed
REFERENCE_DIR=reference
LOGS_DIR=logs

# =================================================================
# Тайминги обработки
# =================================================================
# Время ожидания генерации в секундах (max)
GENERATION_TIMEOUT_SEC=300
# Пауза между обработкой файлов (секунды) — чтобы не вызвать рейт-лимит
DELAY_BETWEEN_JOBS_SEC=5

# =================================================================
# Google Drive загрузка результатов
# =================================================================
# Само значение GDRIVE_CREDENTIALS_JSON используется как флаг "Drive настроен"
# и как имя файла с OAuth client secret (рядом с проектом).
# Сам токен пользователя — в gdrive_token.json (создаётся python gdrive_auth.py).
GDRIVE_CREDENTIALS_JSON=client_secret_XXXXX.apps.googleusercontent.com.json

# Общая папка (используется если для режима не задана своя)
GDRIVE_FOLDER_ID=

# Папки по режимам (если пусто — берётся общая GDRIVE_FOLDER_ID)
RITUAL_GDRIVE_FOLDER_ID=
CONDITIONER_GDRIVE_FOLDER_ID=
WREATH_GDRIVE_FOLDER_ID=

# =================================================================
# Режим VPS-агента (remote_agent.py) — Telegram-бот на VPS,
# локальный ПК через SSH-туннель опрашивает /api/next-job
# =================================================================
# Адрес и кредентиалы продакшен-VPS (хостинг бота и API очереди)
VPS_SSH_HOST=213.109.202.45
VPS_SSH_USER=root
VPS_SSH_PASS=
# Порт API внутри VPS (наружу не открыт — только через SSH-туннель)
VPS_API_PORT=8765
# Токен для авторизации запросов агента к /api/next-job, /api/complete и т.д.
VPS_API_TOKEN=
# Как часто локальный агент опрашивает VPS (секунды)
POLL_INTERVAL_SEC=10
